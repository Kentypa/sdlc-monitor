# SDLC Monitor — API Environment Variables
# Скопируй этот файл: cp .env.example .env
# и заполни реальными значениями.

# PostgreSQL connection string
DATABASE_URL="postgresql://sdlc:secret@localhost:5432/sdlcdb"

# GitHub Personal Access Token
# Создай на: https://github.com/settings/tokens
# Требуемые права: repo (read), read:user
# Без токена: лимит 60 req/hour; с токеном: 5000 req/hour
GITHUB_TOKEN="ghp_yourPersonalAccessTokenHere"

# API Server Port
PORT=3000

# Environment
NODE_ENV=development
