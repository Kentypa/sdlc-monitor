# Git ignore rules for SDLC Monitor monorepo

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/

# Environment variables (NEVER commit these!)
.env
.env.local
.env.*.local

# Prisma generated files
api/prisma/migrations/dev.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
.docker/

# Coverage
coverage/
